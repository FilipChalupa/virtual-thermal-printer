{
	"name": "virtual-thermal-printer",
	"version": "0.0.29",
	"private": true,
	"type": "module",
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"start": "tsx main.ts",
		"dev": "npm run build && concurrently \"npm run build:watch\" \"tsx watch --conditions=source main.ts --http 8000\"",
		"build": "tsx --conditions=source scripts/build.ts --production",
		"build:watch": "tsx watch --conditions=source scripts/build.ts",
		"test": "vitest run",
		"sea:bundle": "tsx scripts/sea.ts",
		"version:bump": "tsx --conditions=source scripts/version.ts"
	},
	"dependencies": {
		"escpos-decoder": "*",
		"@hono/node-server": "^1.13.7",
		"hono": "^4.6.5",
		"ws": "^8.20.0"
	},
	"devDependencies": {
		"@types/node": "^22.10.2",
		"@types/ws": "^8.18.1",
		"concurrently": "^9.1.2",
		"esbuild": "^0.24.2",
		"tsx": "^4.19.2",
		"typescript": "^5.7.3",
		"vitest": "^2.1.8"
	}
}
